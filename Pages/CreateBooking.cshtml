@page
@model dsv_mini.Pages.CreateBookingModel
@{
    <h2>Opret booking for lokale nr. @Model.NewBooking.RoomId</h2>

    <form method="post">
        <!-- Skjult felt der husker hvilket lokale vi booker -->
        <input type="hidden" asp-for="NewBooking.RoomId" />

        <div class="form-group">
            <label>Mødeansvarlig:</label>
            <input asp-for="NewBooking.Organizer" class="form-control" />
        </div>

        <div class="form-group">
            <label>Start:</label>
            <input asp-for="NewBooking.StartTime" type="datetime-local" class="form-control" />
        </div>

        <div class="form-group">
            <label>Slut:</label>
            <input asp-for="NewBooking.EndTime" type="datetime-local" class="form-control" />
        </div>

        <div class="form-group">
            <label>Evt. kommentar:</label>
            <input asp-for="NewBooking.Comment" type="text" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Bekræft booking</button>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}
